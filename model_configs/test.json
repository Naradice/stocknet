{
  "dataset": {
    "key": "seq2seq",
    "source": [
      {
        "file_path": "C:\\Users\\ksato\\workspace\\python\\stock\\Data\\FX\\OANDA-Japan MT5 Live\\mt5_USDJPY_h1.csv",
        "scale_combinations": [
          {
            "volume_rate": 0.25,
            "batch_size": 16
          },
          {
            "volume_rate": 0.5,
            "batch_size": 32
          },
          {
            "volume_rate": 0.75,
            "batch_size": 64
          },
          {
            "volume_rate": 1,
            "batch_size": 128
          }
        ]
      }
    ],
    "args": {
      "columns": [
        "open",
        "high",
        "low",
        "close"
      ],
      "processes": [
        "Diff",
        "MiniMax"
      ]
    },
    "observation": 60,
    "prediction": 10
  },
  "model": {
    "key": "Seq2SeqTransformer",
    "model_name": "test",
    "params": {
      "nhead": 4,
      "dim_feedforward": 128,
      "num_encoder_layers": 2,
      "num_decoder_layers": 2,
      "dropout": 0.1,
      "d_model": 64,
      "positional_encoding": {
        "key": "PositionalEncoding",
        "d_model": 64,
        "max_len": 5000,
        "dropout": 0.05
      },
      "input_layer": {
        "key": "Perceptron",
        "input_dim": 4,
        "output_dim": 64,
        "num_layers": 1
      },
      "output_layer": {
        "key": "Perceptron",
        "input_dim": 64,
        "output_dim": 4,
        "num_layers": 1
      }
    }
  },
  "training": {
    "optimizer": {
      "key": "AdamW",
      "lr": 0.001
    },
    "scheduler": {
      "key": "StepLR",
      "step_size": 10,
      "gamma": 0.5
    },
    "loss": {
      "key": "MSELoss"
    },
    "epoch": 100,
    "patience": 5
  },
  "log": {
    "path": "./logs"
  }
}