# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Shared by both the Python training pipeline and the Next.js web app.
# Copy this file to .env and fill in your values.

PGHOST=localhost
PGPORT=5432
PGDATABASE=stocknet
PGUSER=postgres
PGPASSWORD=

# ── Training defaults (optional) ──────────────────────────────────────────────
# Override the default CUDA device used during training.
# STOCKNET_DEVICE=cuda
